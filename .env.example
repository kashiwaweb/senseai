# senseai 環境変数テンプレート
#
# 使い方:
#   1. このファイルを `.env` にコピー: cp .env.example .env
#   2. 必要な値を埋める（取得元は各セクションのコメント参照）
#   3. .env はコミット禁止（.gitignore で除外済み）
#
# 詳細は docs/architecture.md §7 を参照。

# ============================================================
# 認証 (W1-08 で使用)
# ============================================================

# 共有パスワード（PoC期は単一パスワードで全員ログイン）
AUTH_PASSWORD=changeme

# セッション暗号化キー（32 文字以上のランダム文字列）
# 生成例: `openssl rand -base64 32`
AUTH_SESSION_SECRET=please_replace_with_a_long_random_string_at_least_32_chars

# ============================================================
# LLM (W1-11 で使用)
# ============================================================

# 使用する LLM プロバイダ: 'gemini' または 'claude'
LLM_PROVIDER=gemini

# Google Gemini API キー
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude API キー（フォールバック用、任意）
# 取得: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ============================================================
# 文字起こし (W2-03 で使用)
# ============================================================

# Groq API キー（Whisper Large-v3-Turbo を使用）
# 取得: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI Whisper API キー（Groq フォールバック用、任意）
# 取得: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================================
# データベース (W1-05 で使用 / Turso libSQL)
# ============================================================

# 本番のみ必要。
# 空の場合は server/db/client.ts がローカル SQLite ファイル (file:local.db) にフォールバック。
#
# 取得手順:
#   1. https://turso.tech でアカウント作成
#   2. `turso db create senseai-poc` で DB 作成
#   3. `turso db show senseai-poc --url` で URL 取得
#   4. `turso db tokens create senseai-poc` で auth token 取得
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ============================================================
# ストレージ (W2-01 で使用 / Cloudflare R2)
# ============================================================

# 音声ファイル保存用バケットの認証情報。
#
# 取得手順:
#   1. Cloudflare ダッシュボード → R2 → バケット作成 (例: senseai-audio)
#   2. R2 → 「APIトークンの管理」 → アクセスキー作成
#   3. アカウント ID は R2 ホーム右上に表示されている
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=senseai-audio
